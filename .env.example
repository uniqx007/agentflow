# ── Copy this file to .env and fill in your values ────────

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=asia-south1

# Gemini / Vertex AI
GEMINI_MODEL=gemini-1.5-pro
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# AlloyDB AI (optional - for vector memory)
ALLOYDB_URL=postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# Google Search API (optional - for web search tool)
GOOGLE_SEARCH_API_KEY=your-api-key-here
GOOGLE_SEARCH_CX=your-custom-search-engine-id
